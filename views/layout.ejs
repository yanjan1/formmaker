<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= typeof title !=='undefined' ? title : 'FormMaker' %>
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --brand: #e60c4d;
      --brand-dark: #660421;
      --brand-light: #ede9ff;
      --surface: #ffffff;
      --bg: #f4f3ff;
      --border: #e4e0fb;
      --text: #1a1523;
      --muted: #7b7494;
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6,
    .navbar-brand,
    .fw-bold,
    .fw-semibold {
      font-family: 'Space Grotesk', sans-serif;
    }

    /* ── Navbar ── */
    .navbar {
      background: var(--surface) !important;
      border-bottom: 1.5px solid var(--border);
      padding: 0.6rem 0;
    }

    .navbar-brand {
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--brand) !important;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .navbar-brand .brand-dot {
      width: 8px;
      height: 8px;
      background: var(--brand);
      border-radius: 50%;
      display: inline-block;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(1.4);
      }
    }

    .nav-link {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 500;
      font-size: 0.9rem;
      color: var(--muted) !important;
      padding: 0.4rem 0.75rem !important;
      border-radius: 6px;
      transition: all 0.15s;
    }

    .nav-link:hover {
      color: var(--text) !important;
      background: var(--brand-light);
    }

    .nav-link.active {
      color: var(--brand) !important;
    }

    .btn-nav-logout {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--brand);
      border: 1.5px solid var(--brand);
      background: transparent;
      padding: 0.3rem 0.9rem;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .btn-nav-logout:hover {
      background: var(--brand);
      color: #fff;
    }

    .dev-mail-link {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      color: #fff !important;
      background: #f59e0b;
      padding: 0.25rem 0.7rem !important;
      border-radius: 20px;
    }

    .dev-mail-link:hover {
      background: #d97706;
      color: #fff !important;
    }

    /* ── Cards ── */
    .card {
      border: 1.5px solid var(--border) !important;
      border-radius: 12px !important;
      box-shadow: 0 2px 8px rgba(108, 71, 255, 0.06) !important;
      background: var(--surface);
    }

    /* ── Buttons ── */
    .btn-dark {
      background: var(--brand) !important;
      border-color: var(--brand) !important;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      border-radius: 8px;
    }

    .btn-dark:hover {
      background: var(--brand-dark) !important;
      border-color: var(--brand-dark) !important;
    }

    .btn-outline-dark {
      color: var(--brand) !important;
      border-color: var(--brand) !important;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      border-radius: 8px;
    }

    .btn-outline-dark:hover {
      background: var(--brand) !important;
      color: #fff !important;
    }

    .btn-outline-secondary {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 500;
      border-radius: 8px;
    }

    .btn-success {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      border-radius: 8px;
    }

    .btn-outline-success {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      border-radius: 8px;
    }

    .btn-outline-danger {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      border-radius: 8px;
    }

    .btn-warning {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      border-radius: 8px;
    }

    /* ── Forms ── */
    .form-control,
    .form-select {
      border: 1.5px solid var(--border);
      border-radius: 8px;
      font-size: 0.9rem;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(108, 71, 255, 0.12);
    }

    .form-label {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
    }

    /* ── Flash ── */
    .flash-bar {
      border-radius: 10px;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      border: none;
      padding: 0.75rem 1.1rem;
    }

    .alert-info {
      background: #ede9ff;
      color: var(--brand);
    }

    .alert-success {
      background: #d1fae5;
      color: #065f46;
    }

    .alert-danger {
      background: #fee2e2;
      color: #991b1b;
    }

    .alert-warning {
      background: #fef3c7;
      color: #92400e;
    }

    /* ── Table ── */
    .table th {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ── Badges ── */
    .badge {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      font-size: 0.72rem;
    }

    /* ── Page container ── */
    .page-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }
  </style>
</head>

<body>

  <% if (!locals.hideNav) { %>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="/">
          <span class="brand-dot"></span>
          FormMaker
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
          style="border-color: var(--border)">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
          <ul class="navbar-nav ms-auto align-items-center gap-1">
            <% if (user) { %>
              <li class="nav-item">
                <a class="nav-link" href="/dashboard">
                  <i class="bi bi-grid me-1"></i>Dashboard
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/studio">
                  <i class="bi bi-ui-checks me-1"></i>Studio
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/account">
                  <i class="bi bi-person me-1"></i>Account
                </a>
              </li>
              <li class="nav-item ms-2">
                <form action="/auth/logout" method="POST" class="d-inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn-nav-logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                  </button>
                </form>
              </li>
              <% } else { %>
                <li class="nav-item">
                  <a class="nav-link" href="/auth/login">Login</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="/auth/register">Register</a>
                </li>
                <% } %>
                  <li class="nav-item ms-2">
                    <a class="nav-link dev-mail-link" href="/email">
                      <i class="bi bi-envelope-fill me-1"></i>Dev Mail
                    </a>
                  </li>
          </ul>
        </div>
      </div>
    </nav>
    <% } %>

      <div class="container page-container">
        <% if (flash) { %>
          <div class="alert flash-bar alert-<%= flash.type %> alert-dismissible fade show mb-4" role="alert">
            <%= flash.message %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <% } %>
            <%- body %>
              <hr class="my-5" />

              <p class="text-dark small text-center">
                Developed by <strong>Yanjanendra Kafaltiya</strong>
              </p>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>