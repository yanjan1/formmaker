<div class="row justify-content-center mt-5">
  <div class="col-md-5 text-center">
    <% if (status === 'ok') { %>
      <i class="bi bi-check-circle-fill text-success fs-1"></i>
      <h3 class="mt-3 fw-bold">Email Verified!</h3>
      <p class="text-muted">Your account is now active.</p>
      <a href="/dashboard" class="btn btn-dark mt-2">Go to Dashboard</a>
    <% } else if (status === 'expired') { %>
      <i class="bi bi-clock-history text-warning fs-1"></i>
      <h3 class="mt-3 fw-bold">Link Expired</h3>
      <p class="text-muted">Your verification link has expired.</p>
      <a href="/auth/request-verify" class="btn btn-outline-dark mt-2">Request New Link</a>
    <% } else { %>
      <i class="bi bi-x-circle-fill text-danger fs-1"></i>
      <h3 class="mt-3 fw-bold">Invalid Link</h3>
      <p class="text-muted">This link is invalid or has already been used.</p>
      <a href="/auth/request-verify" class="btn btn-outline-dark mt-2">Request New Link</a>
    <% } %>
  </div>
</div>