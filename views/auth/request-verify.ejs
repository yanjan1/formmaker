<div class="row justify-content-center mt-5">
  <div class="col-md-5 text-center">
    <% if (sent) { %>
      <i class="bi bi-envelope-check text-success fs-1"></i>
      <h3 class="mt-3 fw-bold">Email Sent</h3>
      <p class="text-muted">Check <a href="/email">/email</a> for your verification link.</p>
    <% } else { %>
      <i class="bi bi-envelope fs-1 text-secondary"></i>
      <h3 class="mt-3 fw-bold">Verify Your Email</h3>
      <p class="text-muted">Click below to receive a new verification link.</p>
      <form action="/auth/request-verify" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="btn btn-dark">Send Verification Email</button>
      </form>
    <% } %>
  </div>
</div>