<div class="row justify-content-center mt-4">
  <div class="col-md-5">
    <div class="card p-4">
      <h3 class="fw-bold mb-1">Forgot Password</h3>
      <p class="text-muted small mb-4">Enter your email and we'll send a reset link.</p>
      <% if (sent) { %>
        <div class="alert alert-success">
          If that email exists, a reset link has been sent. Check <a href="/email">/email</a>.
        </div>
      <% } else { %>
        <form action="/auth/forgot-password" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required autofocus />
          </div>
          <button class="btn btn-dark w-100">Send Reset Link</button>
        </form>
      <% } %>
      <hr />
      <p class="small text-center mb-0"><a href="/auth/login">Back to login</a></p>
    </div>
  </div>
</div>