<div class="row justify-content-center mt-4">
  <div class="col-md-5">
    <% if (status === 'form') { %>
      <div class="card p-4">
        <h3 class="fw-bold mb-4">Set New Password</h3>
        <form action="/auth/reset-password" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />  
          <input type="hidden" name="token" value="<%= token %>" />
          <div class="mb-3">
            <label class="form-label">New Password <small class="text-muted">(min 8 chars)</small></label>
            <input type="password" name="password" class="form-control" minlength="8" required autofocus />
          </div>
          <button class="btn btn-dark w-100">Reset Password</button>
        </form>
      </div>
    <% } else if (status === 'done') { %>
      <div class="text-center mt-5">
        <i class="bi bi-check-circle-fill text-success fs-1"></i>
        <h3 class="mt-3 fw-bold">Password Reset!</h3>
        <p class="text-muted">You can now log in with your new password.</p>
        <a href="/auth/login" class="btn btn-dark mt-2">Login</a>
      </div>
    <% } else { %>
      <div class="text-center mt-5">
        <i class="bi bi-x-circle-fill text-danger fs-1"></i>
        <h3 class="mt-3 fw-bold">Invalid or Expired Link</h3>
        <p class="text-muted">Request a new one below.</p>
        <a href="/auth/forgot-password" class="btn btn-outline-dark mt-2">Try Again</a>
      </div>
    <% } %>
  </div>
</div>