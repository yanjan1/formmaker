<div class="row justify-content-center mt-4">
  <div class="col-md-5">
    <div class="card p-4">
      <h3 class="fw-bold mb-4">Change Password</h3>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <form action="/account/change-password" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="mb-3">
          <label class="form-label">Current Password</label>
          <input type="password" name="currentPassword" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">New Password <small class="text-muted">(min 8 chars)</small></label>
          <input type="password" name="newPassword" class="form-control" minlength="8" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Confirm New Password</label>
          <input type="password" name="confirmPassword" class="form-control" required />
        </div>
        <button class="btn btn-dark w-100">Update Password</button>
      </form>
      <hr />
      <p class="small text-center mb-0"><a href="/account">← Back to Account</a></p>
    </div>
  </div>
</div>